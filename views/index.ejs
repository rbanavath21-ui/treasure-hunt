<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Enigma Project</title>
    <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg-color: #050505;
            --panel-bg: #111;
            --primary-glow: #00ffcc; 
            --text-main: #e0e0e0;
            --error-color: #ff3366; 
            --success-color: #33ff33;
            --hint-color: #ffcc00; 
        }
        body { font-family: 'Share Tech Mono', monospace; background-color: var(--bg-color); color: var(--text-main); display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .game-container { background-color: var(--panel-bg); width: 90%; max-width: 600px; padding: 50px; border-radius: 4px; border: 1px solid #333; box-shadow: 0 0 20px rgba(0, 255, 204, 0.05); text-align: center; animation: fadeIn 0.8s ease-in-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
        h1 { color: var(--primary-glow); text-transform: uppercase; letter-spacing: 3px; margin-bottom: 30px; text-shadow: 0 0 10px rgba(0, 255, 204, 0.3); }
        .level-indicator { font-size: 0.9em; color: #666; margin-bottom: 15px; text-transform: uppercase; letter-spacing: 2px;}
        .hint-box { background: rgba(0, 255, 204, 0.1); border-left: 4px solid var(--primary-glow); padding: 15px; margin-bottom: 25px; color: var(--primary-glow); font-size: 1.1em; text-transform: uppercase;}
        .riddle-text { font-size: 1.4em; line-height: 1.6; margin-bottom: 40px; color: #fff; }
        input[type="text"] { width: 80%; padding: 15px; margin-bottom: 20px; background: #000; border: 1px solid #444; color: var(--primary-glow); font-family: 'Share Tech Mono', monospace; font-size: 1.2em; text-align: center; transition: 0.3s; outline: none; }
        input[type="text"]:focus { border-color: var(--primary-glow); box-shadow: 0 0 15px rgba(0, 255, 204, 0.4); }
        button.submit-btn { background-color: transparent; color: var(--primary-glow); padding: 12px 40px; border: 1px solid var(--primary-glow); font-family: 'Share Tech Mono', monospace; font-size: 1.2em; cursor: pointer; transition: 0.3s; text-transform: uppercase; letter-spacing: 1px; }
        button.submit-btn:hover { background-color: var(--primary-glow); color: #000; box-shadow: 0 0 20px var(--primary-glow); }
        .error { color: var(--error-color); margin-top: 20px; text-shadow: 0 0 5px var(--error-color); }
        .victory-container { border: 1px solid var(--success-color); box-shadow: 0 0 30px rgba(51, 255, 51, 0.2); padding: 40px; }
        .victory-title { color: var(--success-color); font-size: 2.5em; text-shadow: 0 0 20px var(--success-color); animation: pulse 1.5s infinite alternate; }
        .victory-text { font-size: 1.2em; color: #ccc; margin-bottom: 30px; line-height: 1.5; }
        @keyframes pulse { from { text-shadow: 0 0 10px var(--success-color); } to { text-shadow: 0 0 30px var(--success-color), 0 0 10px #fff; } }
        
        /* --- CUSTOM HINT SYSTEM STYLES --- */
        .ask-hint-btn { background: none; border: none; color: #555; text-decoration: underline; cursor: pointer; font-family: 'Share Tech Mono', monospace; margin-top: 25px; font-size: 0.9em; transition: 0.3s; }
        .ask-hint-btn:hover { color: var(--error-color); }
        
        /* The custom sarcastic warning box */
        .system-warning { display: none; margin-top: 25px; border: 1px solid var(--error-color); background: rgba(255, 51, 102, 0.05); padding: 20px; color: var(--error-color); animation: fadeIn 0.3s ease-in-out; }
        .system-warning p { margin: 0 0 15px 0; font-size: 0.95em; line-height: 1.4; }
        
        /* Warning buttons */
        .warn-btn { background: transparent; font-family: 'Share Tech Mono', monospace; cursor: pointer; padding: 8px 15px; margin: 0 5px; font-size: 0.9em; transition: 0.2s; }
        .btn-yes { border: 1px solid var(--error-color); color: var(--error-color); }
        .btn-yes:hover { background: var(--error-color); color: #000; }
        .btn-no { border: 1px solid #555; color: #aaa; }
        .btn-no:hover { border-color: var(--primary-glow); color: var(--primary-glow); }

        /* The actual hint display */
        .revealed-hint { display: none; color: var(--hint-color); margin-top: 25px; font-size: 1em; border: 1px dashed var(--hint-color); padding: 15px; background: rgba(255, 204, 0, 0.05); text-shadow: 0 0 5px rgba(255, 204, 0, 0.3); animation: fadeIn 0.5s ease-in-out; }
    </style>
</head>
<body>

    <div class="game-container <%= locals.victory ? 'victory-container' : '' %>">
        
        <% if (locals.startScreen) { %>
            <h1>The Enigma Project</h1>
            <div style="font-size: 1.2em; color: #ccc; margin-bottom: 40px; line-height: 1.8;">
                <p>Welcome, Operative.</p>
                <p>Your mission is to decipher the linked sequence.</p>
                <p style="color: var(--primary-glow); border: 1px dashed var(--primary-glow); padding: 10px; margin-top: 20px;">
                    WARNING: The solution to one protocol is the key to the next. Pay attention.
                </p>
            </div>
            <form action="/play" method="GET">
                <button class="submit-btn" type="submit">INITIALIZE SEQUENCE</button>
            </form>

        <% } else if (locals.victory) { %>
            <h1 class="victory-title">ACCESS GRANTED</h1>
            <div class="victory-text">
                <p>All sequences successfully resolved.</p>
                <p>System override complete.</p>
            </div>
            <form action="/" method="GET">
                <button class="submit-btn" style="color: var(--success-color); border-color: var(--success-color);" type="submit">REBOOT SYSTEM</button>
            </form>
        
        <% } else { %>
            <h1>The Enigma Project</h1>

            <div class="level-indicator">Sequence // 0<%= riddle.stepNumber %></div>

            <% if (locals.message) { %>
                <div class="hint-box"><%= message %></div>
            <% } %>

            <div class="riddle-text">
                "<%= riddle.question %>"
            </div>

            <form action="/verify" method="POST">
                <input type="hidden" name="stepNumber" value="<%= riddle.stepNumber %>">
                <input type="text" name="userAnswer" placeholder="ENTER SOLUTION..." required autocomplete="off" autofocus>
                <br>
                <button class="submit-btn" type="submit">Submit</button>
            </form>

            <% if (locals.error) { %>
                <p class="error"><%= error %></p>
            <% } %>

            <button type="button" id="askHintBtn" class="ask-hint-btn" onclick="triggerWarning()">[ Request Assistance ]</button>
            
            <div id="systemWarningBox" class="system-warning">
                <p>> SYSTEM WARNING: Brain capacity deemed insufficient.</p>
                <p>> Are you seriously giving up already?</p>
                <button type="button" class="warn-btn btn-no" onclick="cancelHint()">ABORT</button>
                <button type="button" class="warn-btn btn-yes" onclick="revealHint()">ADMIT DEFEAT</button>
            </div>

            <div id="hintDisplay" class="revealed-hint">
                > DECRYPTED HINT: <%= riddle.hint %>
            </div>

        <% } %>

    </div>

    <script>
        function triggerWarning() {
            // Hide the 'Ask' button and show the red warning box
            document.getElementById('askHintBtn').style.display = 'none';
            document.getElementById('systemWarningBox').style.display = 'block';
        }

        function cancelHint() {
            // Hide the warning box and bring back the 'Ask' button
            document.getElementById('systemWarningBox').style.display = 'none';
            document.getElementById('askHintBtn').style.display = 'inline-block';
        }

        function revealHint() {
            // Hide the warning box and show the glowing yellow hint
            document.getElementById('systemWarningBox').style.display = 'none';
            document.getElementById('hintDisplay').style.display = 'block';
        }
    </script>
</body>
</html>