<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Enigma Project: Treasure Hunt</title>
    <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap" rel="stylesheet">
    
    <style>
        /* FIXED: Removed the duplicate :root */
        :root {
            --bg-color: #05050a; /* Pitch black */
            --primary-glow: #00ffcc; /* Cyberpunk Neon Cyan */
            --error-color: #ff3366; 
            --success-color: #33ff33; 
            --text-main: #e0e0e0; 
            --hint-color: #ffcc00; 
            --gold-color: #00ffcc; /* Changed to cyan to keep the "gold" logic working but glowing cyan */
        }

        body, html { 
            margin: 0; padding: 0; width: 100%; height: 100%; 
            background: var(--bg-color);
            background-image: radial-gradient(circle at center, rgba(0, 255, 204, 0.05) 0%, rgba(5, 5, 10, 1) 100%);
            font-family: 'Share Tech Mono', monospace; 
            overflow: hidden; color: var(--text-main);
        }

        /* --- THE TITLE --- */
        h1.main-title {
            color: var(--primary-glow);
            text-shadow: 0 0 15px rgba(0, 255, 204, 0.6);
            margin: 0; padding-top: 10px; font-size: 2.5em; text-align: center; text-transform: uppercase;
        }
        .header-clue {
            color: var(--primary-glow); font-size: 0.9em; margin: 10px 0; text-transform: uppercase; letter-spacing: 1px;
        }

        /* --- SAGA VIEWPORT (Map Section) --- */
        .map-viewport { width: 100vw; height: 100vh; overflow-y: auto; overflow-x: hidden; position: relative; background: transparent; scroll-behavior: smooth; }
        
        /* The container that holds the map. Fixed height calculation! */
        .saga-road { width: 100%; max-width: 800px; height: <%= (locals.totalSteps * 180) + 400 %>px; margin: 0 auto; position: relative; }

        /* General page vignette */
        body::after { content: ''; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: radial-gradient(circle at center, transparent 30%, rgba(0, 0, 0, 0.7) 100%); pointer-events: none; z-index: 999; }

        /* --- THE MATRIX CANVAS --- */
        /* FIXED: ensure it sits perfectly behind everything but above the body background */
        #matrixCanvas { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; opacity: 0.8; }

        /* --- MAP NODES & LABELS --- */
        .node-container { position: absolute; width: 120px; height: 100px; display: flex; flex-direction: column; justify-content: center; align-items: center; z-index: 20; text-align: center; margin-left: -60px; /* Centers the div perfectly */ }
        .level-node { width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 2px solid rgba(0, 255, 204, 0.2); background: rgba(0,0,0,0.8); transition: 0.3s; position: relative; }
        .node-icon { font-size: 2em; }
        .node-label { color: var(--text-main); font-weight: bold; font-size: 0.8em; text-align: center; margin-top: 10px; text-shadow: 0 0 5px rgba(0,0,0,0.8); }

        .node-completed .node-label { color: var(--success-color); }
        .node-current .level-node::after {
            content: ''; position: absolute; top: -10px; left: -10px; right: -10px; bottom: -10px;
            border-radius: 50%; box-shadow: 0 0 20px rgba(0, 255, 204, 0.8); pointer-events: none;
            animation: pulseCurrentNode 1.5s infinite;
        }
        @keyframes pulseCurrentNode { 0%, 100% { opacity: 0.6; transform: scale(1); } 50% { opacity: 1; transform: scale(1.05); } }
        .node-locked { opacity: 0.5; cursor: not-allowed; filter: grayscale(100%); }

        /* --- THE SOLID PATH LINE --- */
        #svgLayer { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 10; }
        .road-path { fill: none; stroke: rgba(0, 255, 204, 0.2); stroke-width: 4; stroke-linecap: round; }

        /* --- THE WALKING AVATAR --- */
        .player-avatar { position: absolute; font-size: 3em; z-index: 100; transition: all 1.2s cubic-bezier(0.68, -0.55, 0.27, 1.55); margin-top: -40px; margin-left: -25px; pointer-events: none; filter: drop-shadow(0 5px 15px rgba(0,0,0,0.8)); }
        .jumping { animation: hop 0.6s infinite alternate; }
        @keyframes hop { from { transform: translateY(0); } to { transform: translateY(-20px); } }

        /* --- UI OVERLAYS --- */
        .header { position: fixed; top: 0; left: 0; width: 100%; z-index: 500; background: rgba(0,0,0,0.85); padding: 15px; text-align: center; border-bottom: 2px solid var(--primary-glow); }
        .game-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: transparent; z-index: 1000; display: flex; justify-content: center; align-items: center; text-align: center; }
        
        /* FIXED: Made the terminal background slightly transparent so matrix rain shows through */
        .terminal-box { background: rgba(5, 5, 10, 0.85); padding: 40px; border: 1px solid var(--primary-glow); border-radius: 4px; box-shadow: 0 0 40px rgba(0,255,204,0.15); width: 90%; max-width: 500px; z-index: 10; backdrop-filter: blur(3px); }
        
        .btn { background: var(--primary-glow); color: black; border: none; padding: 15px 30px; font-weight: bold; cursor: pointer; text-transform: uppercase; transition: 0.2s; font-family: 'Share Tech Mono', monospace; letter-spacing: 2px; }
        .btn:hover { background: #fff; box-shadow: 0 0 20px var(--primary-glow); }

        .shake { animation: shake 0.4s cubic-bezier(.36,.07,.19,.97) both; border-color: var(--error-color) !important; box-shadow: 0 0 40px rgba(255, 51, 102, 0.4) !important; }
        @keyframes shake { 10%, 90% { transform: translate3d(-2px, 0, 0); } 20%, 80% { transform: translate3d(3px, 0, 0); } 30%, 50%, 70% { transform: translate3d(-5px, 0, 0); } 40%, 60% { transform: translate3d(5px, 0, 0); } }
        
        /* Integrity Bar */
        .integrity-container { margin-bottom: 20px; color: var(--primary-glow); font-size: 1.1em; font-weight: bold; }
        .integrity-nodes { display: flex; justify-content: center; gap: 10px; margin-top: 10px; }
        .integrity-nodes span { display: inline-block; width: 20px; height: 20px; border-radius: 0; border: 1px solid var(--primary-glow); transition: 0.3s; box-shadow: 0 0 10px var(--primary-glow); }
        .integrity-nodes span.filled { background: var(--primary-glow); }
        .integrity-nodes span.lost { background: transparent; box-shadow: none; border-color: var(--error-color); border-style: solid; }

        /* Hint System */
        .ask-hint-btn { background: none; border: none; color: #aaa; text-decoration: underline; cursor: pointer; font-family: 'Share Tech Mono', monospace; margin-top: 25px; font-size: 0.9em; transition: 0.3s; }
        .ask-hint-btn:hover { color: var(--error-color); }
        .system-warning { display: none; margin-top: 25px; border: 1px solid var(--error-color); background: rgba(255, 51, 102, 0.05); padding: 20px; color: var(--error-color); }
        .revealed-hint { display: none; color: var(--hint-color); margin-top: 25px; font-size: 1em; border: 1px dashed var(--hint-color); padding: 15px; background: rgba(255, 204, 0, 0.05); }
        
    </style>
</head>
<body onclick="initAudio()"> 
    
    <% if (locals.mapScreen) { %>
        <div class="header">
            <h1 class="main-title">THE ENIGMA PROJECT</h1>
            <% if (locals.passedHint) { %> <div class="header-clue">CLUE SECURED: <%= passedHint %></div> <% } %>
        </div>

        <div class="map-viewport" id="viewport">
            <div class="saga-road" id="roadContainer">
                
                <svg id="svgLayer">
                    <path id="mainPath" class="road-path" d="" />
                </svg>

                <div class="player-avatar" id="avatar">🕵️‍♂️</div>

                <% 
                    let mapHeight = (locals.totalSteps * 180) + 400;
                    
                    for(let i = 1; i <= locals.totalSteps; i++) { 
                        const riddle = locals.riddles.find(r => r.stepNumber === i); 
                        
                        let yPos = mapHeight - (i * 180);
                        let xPos = 50 + (Math.sin(i * 1.5) * 35); 
                        
                        let statusClass = ''; 
                        if (i < locals.currentStep) statusClass = 'node-completed';
                        else if (i === locals.currentStep) statusClass = 'node-current';
                        else statusClass = 'node-locked';
                %>
                    
                    <div class="node-container <%= statusClass %>" style="left: <%= xPos %>%; top: <%= yPos %>px;" id="container-<%= i %>">
                        <% if (i === locals.currentStep) { %> 
                            <a href="/play/<%= i %>?hint=<%= locals.passedHint || '' %>" class="level-node" id="node-<%= i %>" onclick="playClick()">
                                <span class="node-icon"><%= riddle.icon %></span>
                            </a>
                        <% } else { %>
                            <div class="level-node" id="node-<%= i %>">
                                <span class="node-icon"><%= riddle.icon %></span>
                            </div>
                        <% } %>
                        <div class="node-label"><%= riddle.label %></div>
                    </div>
                <% } %>
            </div>
        </div>

        <script>
            window.onload = () => {
                const avatar = document.getElementById('avatar');
                const viewport = document.getElementById('viewport');
                const road = document.getElementById('mainPath');
                
                const nodes = [];

                <% for(let i = 1; i <= locals.totalSteps; i++) { %>
                    nodes.push(document.getElementById('node-<%= i %>'));
                <% } %>

                let d = "";
                nodes.forEach((node, idx) => {
                    const rect = node.parentElement; 
                    const x = rect.offsetLeft + 60; 
                    const y = rect.offsetTop + 40;  
                    d += (idx === 0 ? "M" : "L") + ` ${x} ${y}`;
                });
                road.setAttribute("d", d);

                const prevNode = document.getElementById('node-<%= locals.previousStep || 1 %>');
                const currNode = document.getElementById('node-<%= locals.currentStep %>');

                if (prevNode && currNode) {
                    const prevContainer = prevNode.parentElement;
                    const currContainer = currNode.parentElement;

                    if ("<%= locals.previousStep %>" !== "<%= locals.currentStep %>") {
                        avatar.style.left = (prevContainer.offsetLeft + 60) + 'px'; 
                        avatar.style.top = (prevContainer.offsetTop + 40) + 'px';
                        
                        setTimeout(() => {
                            avatar.classList.add('jumping');
                            avatar.style.left = (currContainer.offsetLeft + 60) + 'px'; 
                            avatar.style.top = (currContainer.offsetTop + 40) + 'px';
                            
                            viewport.scrollTop = currContainer.offsetTop - (window.innerHeight / 2);

                            setTimeout(() => avatar.classList.remove('jumping'), 1200);
                            playSuccess(); 
                        }, 500);
                    } else {
                        avatar.style.left = (currContainer.offsetLeft + 60) + 'px'; 
                        avatar.style.top = (currContainer.offsetTop + 40) + 'px';
                        viewport.scrollTop = currContainer.offsetTop - (window.innerHeight / 2);
                    }
                }
            };
        </script>

    <% } else { %>
        <div class="game-overlay">
            
            <canvas id="matrixCanvas"></canvas>

            <div class="terminal-box <%= locals.systemCrash ? 'system-integrity-crash' : (locals.error ? 'shake' : '') %>">
                
                <% if (locals.startScreen) { %>
                    <h1 class="main-title" style="margin-bottom: 20px;">ENIGMA PROTOCOL</h1>
                    <p>Operative, the path through Riddle Cave is hidden. Decoding the protocol is your only path forward. Begin your journey.</p>
                    <form action="/map" method="GET"><button class="btn" type="submit" onclick="playClick()">Start Adventure</button></form>
                
                <% } else if (locals.systemCrash) { %>
                    <h1 style="color:var(--error-color); font-size: 3em;">PROTOCOL CRASHED</h1>
                    <p style="color:#aaa;">System integrity has been fully compromised. Retrying from your last node is required.</p>
                    <form action="/map" method="GET">
                        <input type="hidden" name="step" value="<%= locals.currentStep %>">
                        <button class="btn" style="background:var(--error-color);" type="submit" onclick="playClick()">REBOOT NODE</button>
                    </form>

                <% } else if (locals.victory) { %>
                    <h1 style="color:var(--success-color); font-size: 3em;">ACCESS GRANTED</h1>
                    <p>You have navigated the entire protocol. Overriding the Logic Dungeon was commendable. The Final Treasure is yours.</p>
                    <form action="/" method="GET"><button class="btn" type="submit" onclick="playClick()">Reboot Protocol</button></form>
                
                <% } else { %>
                    <div class="integrity-container">
                        SYSTEM INTEGRITY <br>
                        <div class="integrity-nodes">
                            <span class="<%= attempts >= 1 ? 'filled' : 'lost' %>"></span>
                            <span class="<%= attempts >= 2 ? 'filled' : 'lost' %>"></span>
                            <span class="<%= attempts >= 3 ? 'filled' : 'lost' %>"></span>
                        </div>
                    </div>

                    <h2 style="color:var(--primary-glow); font-size: 1.6em;">Level <%= riddle.stepNumber %>: <%= riddle.label %></h2>
                    
                    <p class="riddle-text glitch-target" data-text="<%= riddle.question %>" style="font-size:1.3em; margin:25px 0;">
                        <%= riddle.question %>
                    </p>
                    
                    <form action="/verify" method="POST">
                        <input type="hidden" name="stepNumber" value="<%= riddle.stepNumber %>">
                        <input type="hidden" name="passedHint" value="<%= locals.passedHint || '' %>">
                        <input type="hidden" name="attempts" value="<%= locals.attempts %>">
                        <input type="text" id="answerInput" name="userAnswer" placeholder="DECRYPT SOLUTION..." required autofocus autocomplete="off" oninput="playType()"
                               style="width:80%; padding:15px; background:rgba(0,0,0,0.8); color:var(--primary-glow); border:1px solid var(--primary-glow); text-align:center; font-family: 'Share Tech Mono', monospace; font-size: 1.2em;">
                        <br><br><button class="btn" type="submit" onclick="playClick()">Verify</button>
                    </form>
                    
                    <% if (locals.error) { %> 
                        <p style="color:var(--error-color); margin-top: 15px; text-shadow: 0 0 10px var(--error-color);"><%= error %></p> 
                        <script> window.onload = () => { setTimeout(() => playError(), 100); initMatrix(); } </script>
                    <% } else { %>
                        <script> window.onload = () => { startDecoder(); initMatrix(); } </script>
                    <% } %>

                    <button type="button" id="askHintBtn" class="ask-hint-btn" onclick="triggerWarning()">[ Request Assistance ]</button>
                    
                    <div id="systemWarningBox" class="system-warning">
                        <p>> WARNING: Cognitive capacity deemed insufficient. Your inability to solve simple puzzles is concerning. Admit defeat?</p>
                        <button type="button" class="btn" style="background:transparent; border:1px solid #aaa; color:#aaa; padding:10px;" onclick="cancelHint()">ABORT</button>
                        <button type="button" class="btn" style="background:transparent; border:1px solid var(--error-color); color:var(--error-color); padding:10px;" onclick="revealHint()">ADMIT DEFEAT</button>
                    </div>

                    <div id="hintDisplay" class="revealed-hint">
                        > HINT: <%= riddle.hint %>
                    </div>

                    <script>
                        function startDecoder() {
                            const el = document.querySelector('.glitch-target');
                            if(!el) return;
                            const original = el.getAttribute('data-text');
                            const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%^&*";
                            let iter = 0;
                            const interval = setInterval(() => {
                                el.innerText = original.split('').map((c, i) => {
                                    if(i < iter) return c;
                                    return chars[Math.floor(Math.random() * chars.length)];
                                }).join('');
                                if(iter >= original.length) clearInterval(interval);
                                iter += 1/2; 
                            }, 30);
                        }

                        function initMatrix() {
                            const canvas = document.getElementById('matrixCanvas');
                            if(!canvas) return;
                            const ctx = canvas.getContext('2d');
                            canvas.width = window.innerWidth; canvas.height = window.innerHeight;
                            
                            const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%^&*'.split('');
                            const fontSize = 16;
                            const columns = canvas.width / fontSize;
                            const drops = [];
                            for(let x = 0; x < columns; x++) drops[x] = 1;

                            setInterval(() => {
                                ctx.fillStyle = 'rgba(5, 5, 10, 0.1)'; 
                                ctx.fillRect(0, 0, canvas.width, canvas.height);
                                ctx.fillStyle = '#00ffcc'; // Hacker neon color
                                ctx.font = fontSize + 'px monospace';

                                for(let i = 0; i < drops.length; i++) {
                                    const text = chars[Math.floor(Math.random() * chars.length)];
                                    ctx.fillText(text, i * fontSize, drops[i] * fontSize);
                                    if(drops[i] * fontSize > canvas.height && Math.random() > 0.975) drops[i] = 0;
                                    drops[i]++;
                                }
                            }, 33);
                        }

                        function triggerWarning() { document.getElementById('askHintBtn').style.display = 'none'; document.getElementById('systemWarningBox').style.display = 'block'; playError(); }
                        function cancelHint() { document.getElementById('systemWarningBox').style.display = 'none'; document.getElementById('askHintBtn').style.display = 'inline-block'; playClick(); }
                        function revealHint() { document.getElementById('systemWarningBox').style.display = 'none'; document.getElementById('hintDisplay').style.display = 'block'; playSuccess(); }
                    </script>
                <% } %>
            </div>
        </div>
    <% } %>

    <script>
        let audioCtx;
        function initAudio() {
            if (!audioCtx) { audioCtx = new (window.AudioContext || window.webkitAudioContext)(); }
            if (audioCtx.state === 'suspended') { audioCtx.resume(); }
        }

        function beep(freq, type, duration, vol) {
            initAudio(); // <--- THIS IS THE MAGIC FIX! Wakes up audio on typing.
            
            if (!audioCtx) return;
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            osc.type = type;
            osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
            gain.gain.setValueAtTime(vol, audioCtx.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + duration);
            osc.connect(gain); gain.connect(audioCtx.destination);
            osc.start(); osc.stop(audioCtx.currentTime + duration);
        }

        function playType() { beep(600, 'square', 0.05, 0.05); } 
        function playClick() { beep(900, 'sine', 0.1, 0.1); } 
        function playError() { beep(150, 'sawtooth', 0.5, 0.2); } 
        function playSuccess() { 
            beep(600, 'sine', 0.1, 0.1); 
            setTimeout(() => beep(800, 'sine', 0.1, 0.1), 100); 
            setTimeout(() => beep(1200, 'sine', 0.2, 0.1), 200); 
        } 
    </script>
</body>
</html>